# Configuração do Supabase (cliente / front-end)
# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase.
# A PUBLISHABLE/ANON key é pública por design (vai para o bundle do front),
# mas NUNCA coloque a SERVICE_ROLE key aqui — ela é secreta e só deve existir
# como secret das Edge Functions no painel do Supabase.

VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"
